{% doc %}
  Outputs a logo. Options for size, image, clickable or not and open in new tab or not
{% enddoc %}



{% stylesheet %}
  
{% endstylesheet %}

{% schema %}
{
    "name": "Logo",
    "settings": [
        {
            "type": "image_picker",
            "id": "logo_image",
            "label": "Logo Image"
        },
        {
            "type": "range",
            "id": "width",
            "label": "Size",
            "min": 1,
            "max": 100,
            "step": 1,
            "unit": "px",
            "default": 32
        },
        {
            "type": "checkbox",
            "id": "url_options",
            "label": "Add Link"
        }
    ]
}
{% endschema %}