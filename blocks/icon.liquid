{% doc %}
  Outputs a logo. Options for size, image, clickable or not and open in new tab or not
{% enddoc %}

{% capture icon %}
  {% render 'icon-or-image',
    icon: block_settings.icon,
    image_upload: block_settings.image_upload,
    width: block_settings.width,
    class_name: icon_block_class,
    attributes: block.shopify_attributes
  %}
{% endcapture %}

{% if block.settings.logo_url != blank %}
    <a href="{{ block.settings.logo_url }}"
    {% if block.settings.open_in_new_tab == true %}
        target="_blank"
    {% endif %}
    >
    {{ icon }}
    </a>
{% else %}

    {{ icon }}
    
{% endif %}

{% stylesheet %}
  
{% endstylesheet %}

{% schema %}
{
    "name": "Logo",
    "settings": [
        {
            "type": "image_picker",
            "id": "logo_image",
            "label": "Logo Image"
        },
        {
            "type": "range",
            "id": "width",
            "label": "Size",
            "min": 1,
            "max": 100,
            "step": 1,
            "unit": "px",
            "default": 32
        },
        {
            "type": "checkbox",
            "id": "url_options",
            "label": "Add Link",
            "default": false
        },
        {
            "type": "url",
            "id": "logo_url",
            "label": "Link",
            "visible_if": "{{ block.settings.url_options == true }}"
        },
        {
            "type": "checkbox",
            "id": "open_in_new_tab",
            "label": "Open in New Tab",
            "visible_if": "{{ block.settings.logo_url != blank }}",
            "default": true
        }
    ]
}
{% endschema %}