{% doc %}
    Outputs an image
{% enddoc %}

    {% if block.settings.image %}
        <img 
            class="image"
            style="{% if block.settings.width == 'custom' %} width: {{block.settings.image_width}}%; {% else %} width: {{block.settings.width}};" 
            src="{{ block.settings.image | image_url: width: 3840 }}" 
            alt="{{block.settings.alt_text}}" 
            width="{{ block.settings.image_width }}" 
            {{ block.shopify_attributes }}>
    {% endif %}

{% stylesheet  %}  
    .image {
        height: 100%;
    }
{% endstylesheet %}

{% schema  %}
{
    "name": "Image",
    "settings": [
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
        },
        {
            "type": "select",
            "id": "width",
            "label": "Width",
            "options": [
                {
                    "value": "fit-content",
                    "label": "Fit Content"
                },
                {
                    "value": "100%",
                    "label": "Fill"
                },
                {
                    "value": "custom",
                    "label": "Custom"
                }
            ],
            "default": "fill"
        },
        {
            "type": "range",
            "id": "image_width",
            "label": "Image Width",
            "min": 0,
            "max": 100,
            "step": 1,
            "unit": "%",
            "default": 100,
            "visible_if": "{{ block.settings.width == 'custom' }}"
        },
        {
            "type": "text",
            "id": "alt_text",
            "label": "Image Alternative Text"
        }
    ],
    "presets": [{ "name": "Image" }]
}
{% endschema %}