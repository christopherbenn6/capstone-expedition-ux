<footer>
  <div class="footer__inner">
    <div class="footer__brand">
      {% for block in section.blocks %}
        {% if block.type =='logo-heading' %}
          {% content_for 'block', type: 'logo-heading', id: 'block.id' %}
          {% endif %}
          {% endfor %}
      </div>
  </div>

  <div class="footer__social">
    {% comment %}
      Social icon blocks will go here
    {% endcomment %}
     {% for block in section.blocks %}
     {% if block.type == 'icon' %}
      {% content_for 'block', type: 'icon', id: 'block,id' %}
      {% endif %}
          {% endfor %}
    </div>

  <div class="footer__links">
    {% for link in section.settings.menu.links %}
      {{ link.title | link_to: link.url }}
    {% endfor %}
  </div>
  <div class="footer__copyright">
    &copy;
    {{ 'now' | date: '%Y' }}
    {{ shop.name | link_to: routes.root_url }}, {{ powered_by_link }}
  </div>
</footer>

{% stylesheet %}
  .footer__inner {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;

  }
  footer a {
    text-decoration: none;
    color: var(--color-foreground);
  }
  footer .footer__links,
  footer .footer__payment {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Footer Menu"
    }
  ],
  "blocks": [{ "type": "@theme" }],
  "presets": [
    {
      "name": "Footer",
      "blocks": [{ "type": "logo-heading" }]
    }
  ]
}
{% endschema %}
