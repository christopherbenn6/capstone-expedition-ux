{% doc %}
    Renders store hours, with options to change hours, and styling.
{% enddoc %}

{% comment %} Div Background Styling {% endcomment %} 
{% if section.settings.show_background_color %} 
    {% style %}  
        .hours-background {
            background-color: {{ section.settings.background_color }}
            border-radius: {{ section.settings.border_radius }}
        }
    {% endstyle %} 
{% endif %}
<div class="hours-background">
    {% if section.settings.show_hours_heading %}
        <h2>{{ section.settings.hours_heading }}</h2>
    {% endif %}
    {% if section.settings.show_hours_content %}
        <h2>{{ section.settings.hours_content }}</h2>
    {% endif %}
    <table>
        <tbody>
            <tr>
                <td>Monday</td>
                <td>{{ section.settings.monday_hours }}</td>
            </tr>
            <tr>
                <td>Tuesday</td>
                <td>{{ section.settings.tuesday_hours }}</td>
            </tr>
            <tr>
                <td>Wednesday</td>
                <td>{{ section.settings.wednesday_hours }}</td>
            </tr>
            <tr>
                <td>Thursday</td>
                <td>{{ section.settings.thursday_hours }}</td>
            </tr>
            <tr>
                <td>Friday</td>
                <td>{{ section.settings.friday_hours }}</td>
            </tr>
            <tr>
                <td>Saturday</td>
                <td>{{ section.settings.saturday_hours }}</td>
            </tr>
            <tr>
                <td>Sunday</td>
                <td>{{ section.settings.sunday_hours }}</td>
            </tr>
        </tbody>
    </table>
</div>



{% schema %}
{
    "name": "Store Hours",
    "tag":  "section",
    "disabled_on": {
        "groups": ["header", "footer"]
    },
    "settings": [
        {
            "type": "checkbox",
            "id": "show_hours_heading",
            "label": "Show Heading",
            "default": true
        },
        {
            "type": "text",
            "id": "hours_heading",
            "label": "Heading",
            "visible_if": "show_hours_heading"
        },
        {
            "type": "checkbox",
            "id": "show_hours_content",
            "label": "Show Content",
            "default": true
        },
        {
            "type": "text",
            "id": "hours_content",
            "label": "Content",
            "visible_if": "show_hours_content"
        },
        {
            "type": "text",
            "id": "monday_hours",
            "label": "Monday",
            "default": "Closed"
        },
        {
            "type": "text",
            "id": "tuesday_hours",
            "label": "Tuesday",
            "default": "Closed"
        },
        {
            "type": "text",
            "id": "wednesday_hours",
            "label": "Wednesday",
            "default": "Closed"
        },
        {
            "type": "text",
            "id": "thursday_hours",
            "label": "Thursday",
            "default": "Closed"
        },
        {
            "type": "text",
            "id": "friday_hours",
            "label": "Friday",
            "default": "Closed"
        },
        {
            "type": "text",
            "id": "saturday_hours",
            "label": "Saturday",
            "default": "Closed"
        },
        {
            "type": "text",
            "id": "sunday_hours",
            "label": "Sunday",
            "default": "Closed"
        },
        {
            "type": "checkbox",
            "id": "show_background_color",
            "label": "Add Background Colour",
            "default": true
        },
        {
            "type": "color",
            "id": "background_color",
            "label": "Background Colour",
            "visible_if": "show_background_color"
        },
        {
            "type": "range",
            "id": "border_radius",
            "label": "Border Radius",
            "visible_if": "show_background_color",
            "default": 0
        }
    ],
    "presets": [
        {
            "name": "Store Hours"
        }
    ]
}
{% endschema %}