<section>
{% for block in section.blocks %}
{% if block.type == 'latest_socials_heading' %}
        <h2>{{ block.settings.heading }}</h2>
  {% endif %}
{% endfor %}

{% render 'social-icons' %}
</section>

{% schema %}
{
    "name": "Social Media",
    "blocks": [
        {
            "type": "@app"
        },
        {
            "type": "latest_socials_heading",
            "name": "Heading",
            "settings": [
                {
                    "type": "inline_richtext",
                    "id": "heading",
                    "label": "Heading",
                    "default": "Find More on Our Socials"
                }
            ]
        },
        {
            "type": "social-image",
            "name": "Social Image",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "social-image",
                    "label": "Social Image",
                }
            ]
        }
    ],
    "presets": [
        {
            "name": "Social Media Icon Links"
        }
    ]
}

{% endschema %}